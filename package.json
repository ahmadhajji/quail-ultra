{
  "name": "quail-ultra",
  "version": "0.9.0-beta.1",
  "description": "UWorld-style desktop question bank browser built on Quail",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "postinstall": "electron-builder install-app-deps",
    "build": "electron-builder",
    "build:mac-arm64": "electron-builder --mac dmg zip --arm64",
    "build:mac-dmg": "./scripts/build_manual_mac_arm64.sh",
    "build:mac-arm64-manual": "./scripts/build_manual_mac_arm64.sh",
    "build:win-x64": "electron-builder --win zip --x64",
    "build:win-installer": "electron-builder --win nsis --x64 --publish never",
    "build:win-release": "electron-builder --win nsis zip --x64 --publish never",
    "release": ""
  },
  "build": {
    "appId": "com.ahmadhajji.quailultra",
    "productName": "Quail Ultra",
    "artifactName": "${productName}-${version}-${arch}.${ext}",
    "mac": {
      "category": "public.app-category.education",
      "icon": "branding/quail-ultra.icns",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "dmg": {
      "icon": "branding/quail-ultra.icns"
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "icon": "branding/quail-ultra.png",
      "category": "Education"
    },
    "win": {
      "icon": "branding/quail-ultra.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "perMachine": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Quail Ultra",
      "artifactName": "${productName}-${version}-${arch}-setup.${ext}"
    }
  },
  "keywords": [],
  "author": "Ahmad Hajji",
  "homepage": "https://github.com/ahmadhajji/quail-ultra",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ahmadhajji/quail-ultra.git"
  },
  "bugs": {
    "url": "https://github.com/ahmadhajji/quail-ultra/issues"
  },
  "license": "MIT",
  "devDependencies": {
    "electron": "^12.0.7",
    "electron-builder": "22.10.5"
  },
  "overrides": {
    "istextorbinary": "5.11.0"
  },
  "dependencies": {
    "axios": "^0.21.1",
    "bootstrap": "^4.6.0",
    "directory-tree": "^2.2.9",
    "electron-store": "^8.0.0",
    "jquery": "^3.6.0",
    "popper.js": "^1.16.1",
    "sanitize-html": "^2.3.3",
    "uuid": "^8.3.2"
  }
}
